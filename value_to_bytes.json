{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "oneOf": [
      {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "const": "static"
          },
          "data": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "pattern": "^(0x[0-9a-fA-F]+)$"
                }
              ]
            }
          }
        },
        "required": [
          "id",
          "type",
          "data"
        ],
        "additionalProperties": false
      },
      {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "const": "dynamic"
          },
          "key": {
            "type": "string"
          },
          "data_type": {
            "type": "string",
            "enum": [
              "I8",
              "U8",
              "I16",
              "U16",
              "I32",
              "U32",
              "I64",
              "U64",
              "F32",
              "F64",
              "BOOL",
              "STRING",
              "BYTES"
            ]
          },
          "endian": {
            "type": "string",
            "enum": [
              "le",
              "be"
            ]
          }
        },
        "required": [
          "id",
          "type",
          "key",
          "data_type",
          "endian"
        ],
        "additionalProperties": false
      },
      {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "const": "metadata_length"
          },
          "ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "data_type": {
            "type": "string",
            "enum": [
              "U8",
              "U16",
              "U32",
              "U64",
              "I8",
              "I16",
              "I32",
              "I64",
              "F32",
              "F64"
            ]
          },
          "endian": {
            "type": "string",
            "enum": [
              "le",
              "be"
            ]
          }
        },
        "required": [
          "id",
          "type",
          "ids",
          "data_type",
          "endian"
        ],
        "additionalProperties": false
      }
    ]
  }
}
